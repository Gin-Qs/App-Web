# Copy to apps/web/.env (or .env.local) and fill in your Supabase project values.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: set to 1 to show the one-click demo accounts on /login.
# NEVER enable this in a real production deploy — it ships demo credentials.
# (In `npm run dev` the demo box is always shown.)
#VITE_DEMO_LOGIN=1
